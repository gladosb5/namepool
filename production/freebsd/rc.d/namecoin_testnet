#!/bin/sh
# PROVIDE: namecoin_testnet
# REQUIRE: LOGIN cleanvar
# KEYWORD: shutdown

#
# Add the following lines to /etc/rc.conf to enable :
# namecoin_testnet_enable (bool):	Set to "NO" by default.
#				Set it to "YES" to enable namecoin
# namecoin_testnet_user (str)		Set to "namecoin" by default.
# namecoin_testnet_group (str)		Set to "namecoin" by default.
# namecoin_testnet_conf (str)		Set to "/namecoin/namecoin.conf" by default.
# namecoin_testnet_data_dir (str)	Set to "/var/db/namecoin" by default.
# namecoin_testnet_syslog_facility(str)	Set to "local0" by default.
# namecoin_testnet_syslog_priority(str)	Set to "info" by default.
# namecoinlimits_enable (bool)	Set to "NO" by default.
#				Set it to "YES" to enable namecoinlimits
# namecoinlimits_args		Set to "-e -U ${namecoin_testnet_user}" by default


. /etc/rc.subr

name="namecoin_testnet"
rcvar=namecoin_testnet_enable

start_precmd="namecoin_testnet_precmd"
start_cmd="namecoin_testnet_start"
restart_precmd="namecoin_testnet_checkconfig"
reload_precmd="namecoin_testnet_checkconfig"
configtest_cmd="namecoin_testnet_checkconfig"
status_cmd="namecoin_testnet_status"
stop_cmd="namecoin_testnet_stop"
stop_postcmd="namecoin_testnet_wait"
command="/usr/local/bin/namecoind"
daemon_command="/usr/sbin/daemon"
extra_commands="configtest"
pidfile="/namecoin/namecoin.pid"

: ${namecoin_testnet_enable:="NO"}
: ${namecoinlimits_enable:="NO"}

load_rc_config ${name}

: ${namecoin_testnet_user:="namecoin"}
: ${namecoin_testnet_group:="namecoin"}
: ${namecoin_testnet_data_dir:="/namecoin"}
: ${namecoin_testnet_config_file:="/namecoin/namecoin.conf"}
: ${namecoin_testnet_syslog_facility:="local0"}
: ${namecoin_testnet_syslog_priority:="info"}
: ${namecoin_testnet_syslog_tag:="namecoin"}
: ${namecoin_testnet_kill_after:="300"}
: ${namecoinlimits_args:="-e -U ${namecoin_testnet_user}"}

# set up dependant variables
procname="${command}"
required_files="${namecoin_testnet_config_file}"
pidfile="${namecoin_testnet_data_dir}/testnet3/namecoind.pid"

namecoin_testnet_checkconfig()
{
  echo "Performing sanity check on namecoin configuration:"
  if [ ! -d "${namecoin_testnet_data_dir}" ]
  then
    echo "Missing data directory: ${namecoin_testnet_data_dir}"
    exit 1
  fi
  chown -R "${namecoin_testnet_user}:${namecoin_testnet_group}" "${namecoin_testnet_data_dir}"

  if [ ! -f "${namecoin_testnet_config_file}" ]
  then
    echo "Missing configuration file: ${namecoin_testnet_config_file}"
    exit 1
  fi
  if [ ! -x "${command}" ]
  then
    echo "Missing executable: ${command}"
    exit 1
  fi
  return 0
}

namecoin_testnet_cleanup()
{
  rm -f "${pidfile}"
}

namecoin_testnet_precmd()
{
  namecoin_testnet_checkconfig

  pid=$(check_pidfile "${pidfile}" "${procname}")
  if [ -z "${pid}" ]
  then
    echo "Namecoind is not running"
    rm -f "${pidfile}"
  fi

  if checkyesno namecoinlimits_enable
  then
    eval $(/usr/bin/limits ${namecoinlimits_args}) 2>/dev/null
  else
    return 0
  fi
}

namecoin_testnet_status()
{
  local pid
  pid=$(check_pidfile "${pidfile}" "${procname}")
  if [ -z "${pid}" ]
  then
    echo "Namecoind is not running"
    return 1
  else
    echo "Namecoind running, pid: ${pid}"
  fi
}

namecoin_testnet_start()
{
  echo "Starting namecoin:"
  cd "${namecoin_testnet_data_dir}" || return 1
  ${daemon_command} \
    -u "${namecoin_testnet_user}" \
    -l "${namecoin_testnet_syslog_facility}" \
    -s "${namecoin_testnet_syslog_priority}" \
    -T "${namecoin_testnet_syslog_tag}" \
    ${command} \
    -testnet \
    -printtoconsole=1 \
    -conf="${namecoin_testnet_config_file}" \
    -datadir="${namecoin_testnet_data_dir}"
}

namecoin_testnet_stop()
{
  echo "Stopping namecoin:"
  pid=$(check_pidfile "${pidfile}" "${procname}")
  if [ -z "${pid}" ]
  then
    echo "Namecoind is not running"
    return 1
  else
    kill ${pid}
  fi
}

namecoin_testnet_wait()
{
  local n="${namecoin_testnet_kill_after}"
  echo "Waiting for namecoin shutdown:"
  while :
  do
    printf '.'
    pid=$(check_pidfile "${pidfile}" "${procname}")
    if [ -z "${pid}" ]
    then
      printf '\n'
      break
    fi
    sleep 1
    n=$((${n} - 1))
    if [ ${n} -eq 0 -a -f "${pidfile}" ]
    then
      printf "\nForce shutdown"
      kill -9 $(cat "${pidfile}")
      for n in 1 2 3
      do
        printf '.'
        sleep 1
      done
      printf '\n'
      break
    fi
  done
  rm -f "${pidfile}"
  echo "Shutdown complete"
}

run_rc_command "$1"
