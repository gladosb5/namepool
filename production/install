################################
# Install all Electrs Cronjobs #
################################
echo "[*] Installing crontabs"
case $OS in
    FreeBSD)
        osSudo "${ROOT_USER}" sh -c "cat > ${NAMECOIN_HOME}/${TEMP_CRON_FILE}" <<EOF
# generated by production/install
EOF
        if [ "${NAMECOIN_TESTNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 10 ; /usr/local/bin/namecoind -testnet >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${NAMECOIN_TESTNET4_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 20 ; /usr/local/bin/namecoind -testnet4 >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${NAMECOIN_SIGNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 30 ; /usr/local/bin/namecoind -signet >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${NAMECOIN_MAINNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 40 ; screen -dmS mainnet /namecoin/electrs/start mainnet' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '33 03 * * * \$HOME/electrs/start mainnet popular-scripts >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${NAMECOIN_TESTNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 50 ; screen -dmS testnet /namecoin/electrs/start testnet' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '31 03 * * * \$HOME/electrs/start testnet popular-scripts >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${NAMECOIN_TESTNET4_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 60 ; screen -dmS testnet4 /namecoin/electrs/start testnet4' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '30 03 * * * \$HOME/electrs/start testnet4 popular-scripts >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${NAMECOIN_SIGNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 70 ; screen -dmS signet /namecoin/electrs/start signet' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '32 03 * * * \$HOME/electrs/start signet popular-scripts >/dev/null 2>&1' >> ${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        fi
        osSudo "${ROOT_USER}" crontab -u "${NAMECOIN_USER}" "${NAMECOIN_HOME}/${TEMP_CRON_FILE}"
        osSudo "${ROOT_USER}" rm -f "${NAMECOIN_HOME}/${TEMP_CRON_FILE}"

        if [ "${NAMECOIN_MAINNET_MINFEE_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" crontab -u "${MINFEE_USER}" "${MEMPOOL_HOME}/${MEMPOOL_REPO_NAME}/production/minfee.crontab"
        fi

        osSudo "${ROOT_USER}" sh -c "cat > ${ELEMENTS_HOME}/${TEMP_CRON_FILE}" <<EOF
# generated by production/install
EOF
        if [ "${ELEMENTS_LIQUID_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 15 ; /usr/local/bin/elementsd -chain=liquidv1 >/dev/null 2>&1' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 35 ; screen -dmS liquidv1 /elements/electrs/start liquid' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '32 03 * * * \$HOME/electrs/start liquid popular-scripts >/dev/null 2>&1' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${ELEMENTS_LIQUIDTESTNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 25 ; /usr/local/bin/elementsd -chain=liquidtestnet >/dev/null 2>&1' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '@reboot sleep 45 ; screen -dmS liquidtestnet /elements/electrs/start liquidtestnet' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
            osSudo "${ROOT_USER}" sh -c "echo '33 03 * * * \$HOME/electrs/start liquidtestnet popular-scripts >/dev/null 2>&1' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${ELEMENTS_LIQUID_ENABLE}" = ON -a "${ELEMENTS_LIQUIDTESTNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '6 * * * * cd \$HOME/asset_registry_db && git pull --quiet origin master && cd \$HOME/asset_registry_testnet_db && git pull --quiet origin master && killall electrs' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
        elif [ "${ELEMENTS_LIQUID_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '6 * * * * cd \$HOME/asset_registry_db && git pull --quiet origin master && killall electrs' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
        elif [ "${ELEMENTS_LIQUIDTESTNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" sh -c "echo '6 * * * * cd \$HOME/asset_registry_testnet_db && git pull --quiet origin master && killall electrs' >> ${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
        fi
        if [ "${ELEMENTS_LIQUID_ENABLE}" = ON -o "${ELEMENTS_LIQUIDTESTNET_ENABLE}" = ON ];then
            osSudo "${ROOT_USER}" crontab -u "${ELEMENTS_USER}" "${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
        fi
        osSudo "${ROOT_USER}" rm -f "${ELEMENTS_HOME}/${TEMP_CRON_FILE}"
    ;;
    Debian)
        crontab_namecoin=()
        if [ "${NAMECOIN_MAINNET_ENABLE}" = ON ];then
            echo "[*] Installing Electrs Mainnet Cronjob"
            crontab_namecoin+="@reboot sleep 30 ; screen -dmS mainnet /namecoin/electrs/start mainnet\n"
        fi
        if [ "${NAMECOIN_TESTNET_ENABLE}" = ON ];then
            echo "[*] Installing Electrs Testnet Cronjob"
            crontab_namecoin+="@reboot sleep 70 ; screen -dmS testnet /namecoin/electrs/start testnet\n"
        fi
        if [ "${NAMECOIN_TESTNET4_ENABLE}" = ON ];then
            echo "[*] Installing Electrs Testnet4 Cronjob"
            crontab_namecoin+="@reboot sleep 110 ; screen -dmS testnet4 /namecoin/electrs/start testnet4\n"
        fi
        if [ "${NAMECOIN_SIGNET_ENABLE}" = ON ];then
            echo "[*] Installing Electrs Signet Cronjob"
            crontab_namecoin+="@reboot sleep 90 ; screen -dmS signet /namecoin/electrs/start signet\n"
        fi
        if [ "${NAMECOIN_MAINNET_ENABLE}" = ON -o "${NAMECOIN_TESTNET_ENABLE}" = ON -o "${NAMECOIN_TESTNET4_ENABLE}" = ON -o "${NAMECOIN_SIGNET_ENABLE}" = ON ];then
            echo "${crontab_namecoin}" | crontab -u "${NAMECOIN_USER}" -
        fi

        crontab_elements=()
        if [ "${ELEMENTS_LIQUID_ENABLE}" = ON ];then
            echo "[*] Installing Liquid Asset Mainnet Cronjob"
            crontab_elements+="6 * * * * cd $HOME/asset_registry_db && git pull origin master >/dev/null 2>&1\n"
        fi
        if [ "${ELEMENTS_LIQUIDTESTNET_ENABLE}" = ON ];then
            echo "[*] Installing Liquid Asset Testnet Cronjob"
            crontab_elements+="6 * * * * cd $HOME/asset_registry_testnet_db && git pull origin master >/dev/null 2>&1\n"
        fi
        if [ "${ELEMENTS_LIQUID_ENABLE}" = ON -o "${ELEMENTS_LIQUIDTESTNET_ENABLE}" = ON ];then
            echo "${crontab_elements}" | crontab -u "${ELEMENTS_USER}" -
        fi
    ;;
esac

##### Mempool -> Namecoin Mainnet instance

if [ "${NAMECOIN_MAINNET_ENABLE}" = ON -o "${NAMECOIN_TESTNET_ENABLE}" = ON -o "${NAMECOIN_TESTNET4_ENABLE}" = ON -o "${NAMECOIN_SIGNET_ENABLE}" = ON ];then
    echo "[*] Creating Mempool instance for Namecoin Mainnet"
    osSudo "${MEMPOOL_USER}" git config --global advice.detachedHead false
    osSudo "${MEMPOOL_USER}" git clone --branch "${MEMPOOL_REPO_BRANCH}" "${MEMPOOL_REPO_URL}" "${MEMPOOL_HOME}/mainnet"

    echo "[*] Checking out Mempool ${MEMPOOL_LATEST_RELEASE} for Namecoin Mainnet"
    osSudo "${MEMPOOL_USER}" sh -c "cd ${MEMPOOL_HOME}/mainnet && git checkout ${MEMPOOL_LATEST_RELEASE}"
fi

