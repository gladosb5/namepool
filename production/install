    osSudo "${ROOT_USER}" chown -R "${NAMECOIN_USER}:${NAMECOIN_GROUP}" "${NAMECOIN_ELECTRS_HOME}"
    if [ "${NAMECOIN_MAINNET_ENABLE}" = ON ];then
        osSudo "${ROOT_USER}" chown -R "${NAMECOIN_USER}:${NAMECOIN_GROUP}" "${ELECTRS_MAINNET_DATA}"
    fi
    if [ "${NAMECOIN_TESTNET_ENABLE}" = ON ];then
        osSudo "${ROOT_USER}" chown -R "${NAMECOIN_USER}:${NAMECOIN_GROUP}" "${ELECTRS_TESTNET_DATA}"
    fi
    if [ "${NAMECOIN_TESTNET4_ENABLE}" = ON ];then
        osSudo "${ROOT_USER}" chown -R "${NAMECOIN_USER}:${NAMECOIN_GROUP}" "${ELECTRS_TESTNET4_DATA}"
    fi
    if [ "${NAMECOIN_SIGNET_ENABLE}" = ON ];then
        osSudo "${ROOT_USER}" chown -R "${NAMECOIN_USER}:${NAMECOIN_GROUP}" "${ELECTRS_SIGNET_DATA}"
    fi

    echo "[*] Cloning Namecoin Electrs repo from ${NAMECOIN_ELECTRS_REPO_URL}"
    osSudo "${NAMECOIN_USER}" git config --global advice.detachedHead false
    osSudo "${NAMECOIN_USER}" git clone --branch "${NAMECOIN_ELECTRS_REPO_BRANCH}" "${NAMECOIN_ELECTRS_REPO_URL}" "${NAMECOIN_HOME}/${NAMECOIN_ELECTRS_REPO_NAME}"

    echo "[*] Checking out Electrs ${NAMECOIN_ELECTRS_LATEST_RELEASE}"
    osSudo "${NAMECOIN_USER}" sh -c "cd ${NAMECOIN_HOME}/${NAMECOIN_ELECTRS_REPO_NAME} && git checkout ${NAMECOIN_ELECTRS_LATEST_RELEASE}"

    case $OS in
        FreeBSD)
           echo "[*] Installing Rust from pkg install"
        ;;
        Debian)
           echo "[*] Installing Rust from rustup.rs"
           osSudo "${NAMECOIN_USER}" sh -c "cd ${NAMECOIN_ELECTRS_HOME} && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y"
        ;;
    esac

    echo "[*] Building Namecoin Electrs release binary"
    osSudo "${NAMECOIN_USER}" sh -c "cd ${NAMECOIN_ELECTRS_HOME} && cargo run --release --bin electrs -- --version"
fi

